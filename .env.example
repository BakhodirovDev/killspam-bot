BOT_TOKEN=your_telegram_bot_token_here

# Required for AI moderation (pure BYOK): encrypts each group's own Gemini key at
# rest. Every group — including yours — sets its key via /setkey; there is no
# shared or operator-wide key.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Without this, /setkey can't store keys and AI is disabled everywhere (regex still runs).
KEY_ENCRYPTION_SECRET=

DATABASE_URL=postgresql://user:password@localhost:5432/spam_bot_db
ADMIN_TELEGRAM_IDS=123456789,987654321

# Public HTTPS base URL for the BYOK key-entry form (Railway provides the domain).
# Railway injects PORT automatically — no need to set it here.
BASE_URL=https://your-app.up.railway.app